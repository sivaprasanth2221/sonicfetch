{
  "manifest_version": 3,
  "name": "SonicFetch Browser Companion",
  "description": "Send the current YouTube page or a clicked YouTube link directly into SonicFetch.",
  "version": "1.1.0",
  "permissions": ["activeTab", "contextMenus", "notifications", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "icons": {
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "128": "assets/icon-128.png"
    },
    "default_title": "SonicFetch",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
